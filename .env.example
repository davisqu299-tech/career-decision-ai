# Mock mode — set to false when connecting real Dify API
DIFY_USE_MOCK=true

# Dify API (chatflow | workflow)
DIFY_APP_MODE=chatflow
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_WORKFLOW_ID=
DIFY_USER_PREFIX=career-ai

# Dify 响应模式：streaming（推荐，绕过网关 504）| blocking
DIFY_RESPONSE_MODE=streaming

# Dify 请求超时（毫秒），streaming 模式下为空闲超时
DIFY_REQUEST_TIMEOUT_MS=120000
